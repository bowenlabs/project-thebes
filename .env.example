# Required for `pnpm db:studio` only — drizzle-kit's d1-http driver talks
# to remote D1 over Cloudflare's HTTP API. Not used by the app itself;
# Workers get their D1 binding from wrangler.jsonc, not these vars.
# Copy to .env (gitignored) and fill in.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
