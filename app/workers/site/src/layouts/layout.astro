---
import { ClientRouter } from "astro:transitions";
import { env } from "cloudflare:workers";
import { buildTokenStyle } from "@core/lib/design-system/build-token-style";
import { getFontConfig } from "@core/lib/font-pairing";
import { getSiteSettings } from "@core/lib/get-site-settings";
import phosphorCss from "@phosphor-icons/web/regular?url";
import "../assets/app.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const settings = await getSiteSettings(env.DB);
const themeName = settings?.theme ?? "citadel";
const fontConfig = getFontConfig(settings?.fontPairing);
const tokenStyle = buildTokenStyle(settings ?? {});
const darkModeClass = settings?.darkMode ? "dark" : undefined;
---

<html lang="en" data-theme={`theme-${themeName}`} class={darkModeClass}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href={`/themes/theme-${themeName}.css`} />
		<link rel="stylesheet" href={fontConfig.importUrl} />
		{/* style tag MUST come after the link tags above — source order wins, see DECISIONS.md G12 */}
		<style set:html={tokenStyle} />
		<link rel="stylesheet" href={phosphorCss} />
		{env.CF_ANALYTICS_TOKEN && (
			<script
				defer
				src="https://static.cloudflareinsights.com/beacon.min.js"
				data-cf-beacon={`{"token": "${env.CF_ANALYTICS_TOKEN}"}`}
			/>
		)}
		<ClientRouter />
	</head>
	<body>
		<script>
			import { mountPreviewTokenListener } from "../scripts/preview-token-listener";
			mountPreviewTokenListener();
		</script>
		<slot />
	</body>
</html>
