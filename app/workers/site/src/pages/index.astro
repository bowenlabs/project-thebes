---
import { env } from "cloudflare:workers";
import { db } from "@bowenlabs/cadmus/db";
import { pages } from "@core/db/schema.generated";
import { eq } from "drizzle-orm";
import Layout from "../layouts/layout.astro";

// `site_settings` stays a hand-written core table (see DECISIONS.md's
// 2026-06-21 entry, which reverses the 2026-06-20 CMS-pivot framing) and
// is read by the layout itself for the design-system token cascade.
// `pages` is the one cadmus/cms collection Cadmea core ships, so this
// page's own query is just the published-pages list.
const publishedPages = await db(env.DB, { pages })
  .select()
  .from(pages)
  .where(eq(pages.status, "published"))
  .all();
---

<Layout title="Thebes">
	<h1>Thebes</h1>
	<ul>
		{publishedPages.map((page) => <li>{page.title}</li>)}
	</ul>
</Layout>
