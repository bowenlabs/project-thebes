---
import { env } from "cloudflare:workers";
import { getSiteSettings } from "@core/lib/get-site-settings";
import { createR2ImageService } from "@core/lib/image-service";
import Layout from "../layouts/layout.astro";

const settings = await getSiteSettings(env.DB);

// Never read settings.logoUrl directly into an <img> — see layout.astro's
// SiteNav usage for the same reasoning.
const imageService = createR2ImageService(env.R2, env.MEDIA_URL);
const renderedLogo = settings?.logoUrl
  ? imageService.render({ url: settings.logoUrl, alt: "" })
  : null;
---

<Layout title={`${settings?.siteName ?? "Thebes"} — Coming soon`} showChrome={false} noindex>
	<section class="flex min-h-screen flex-col items-center justify-center gap-6 px-[var(--spacing-container-x)] text-center">
		{renderedLogo && (
			<img
				src={renderedLogo.src}
				srcset={renderedLogo.srcset}
				sizes={renderedLogo.sizes}
				alt=""
				width="64"
				height="64"
				loading="eager"
				decoding="async"
			/>
		)}
		<h1 class="font-display text-4xl font-semibold">{settings?.siteName ?? "Thebes"}</h1>
		<p class="text-lg opacity-80">Coming soon.</p>
		<a href="/" class="btn btn-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">
			Back to home
		</a>
	</section>
</Layout>
