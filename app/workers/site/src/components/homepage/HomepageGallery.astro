---
import { env } from "cloudflare:workers";
import type { SiteSettings } from "@core/lib/get-site-settings";
import { createR2ImageService } from "@core/lib/image-service";

interface Props {
  settings: SiteSettings | null;
  heroTitle: string;
  heroBody?: string | null;
}

const { settings, heroTitle, heroBody } = Astro.props;

// Never read settings.logoUrl directly into an <img> — see layout.astro's
// SiteNav usage for the same reasoning.
const imageService = createR2ImageService(env.R2, env.MEDIA_URL);
const renderedLogo = settings?.logoUrl
  ? imageService.render({ url: settings.logoUrl, alt: "" })
  : null;
---

<section class="px-[var(--spacing-container-x)] py-[var(--spacing-section-y)]">
	<div class="grid gap-[var(--spacing-grid-gap)] md:grid-cols-2 md:items-center">
		<div>
			<h1 class="font-display text-4xl font-semibold">{heroTitle}</h1>
			{heroBody && <p class="mt-4 text-lg opacity-80">{heroBody}</p>}
		</div>
		<div class="aspect-square overflow-hidden rounded-box bg-base-200">
			{renderedLogo && (
				<img
					src={renderedLogo.src}
					srcset={renderedLogo.srcset}
					sizes={renderedLogo.sizes}
					alt=""
					loading="lazy"
					decoding="async"
					class="h-full w-full object-cover"
				/>
			)}
		</div>
	</div>
</section>
